# Environment for DeepSeek-V4-Flash "Aiden" recipe (DGX Spark GB10, 2 nodes)
# Source: https://forums.developer.nvidia.com/t/.../372268
#
# These are mirrored in the `env:` block of deepseek-v4-flash.yaml so that
# `sparkrun run` applies them automatically. This standalone file exists for:
#   - docker / docker-compose runs that take an --env-file
#   - manual `export $(grep -v '^#' deepseek-v4-flash.env | xargs)` sessions
# Keep the two in sync if you change anything.

# --- vLLM / DeepSeek-V4 ---
VLLM_ALLOW_LONG_MAX_MODEL_LEN=1
VLLM_USE_B12X_MOE=1
VLLM_SPARSE_INDEXER_MAX_LOGITS_MB=256

# --- CUDA arch (GB10 = sm_121a / Blackwell) ---
TORCH_CUDA_ARCH_LIST=12.1a
FLASHINFER_CUDA_ARCH_LIST=12.1a

# --- NCCL over the ConnectX-7 / InfiniBand-RoCE link between the two Sparks ---
NCCL_NET=IB
NCCL_IB_DISABLE=0
NCCL_IB_GID_INDEX=3
NCCL_CROSS_NIC=1
NCCL_CUMEM_ENABLE=0
NCCL_IGNORE_CPU_AFFINITY=1
NCCL_DEBUG=WARN

# --- Per-node multi-node coordination (set by the orchestrator, NOT here) -------
# The original docker-compose passes these per container. sparkrun's
# vllm-distributed runtime injects them; only set them manually if you launch the
# container yourself (e.g. raw docker run on each node):
#   NODE_RANK=0            # 0 on the head/master node, 1 on the worker
#   MASTER_ADDR=169.254.225.22   # head node CX-7 IP
#   MASTER_PORT=25000
#   HEADLESS=              # set non-empty on worker nodes to pass --headless
