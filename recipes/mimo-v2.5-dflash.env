# Environment for MiMo-V2.5-NVFP4 + DFlash recipe (DGX Spark GB10, 2 nodes)
# Source: https://github.com/DoctorMasterNewb/vLLM-Mimo-V2.5-Dflash-2x-DGX-Spark
#
# These mirror the `env:` block of mimo-v2.5-dflash.yaml (which mirrors the
# upstream scripts/serve.sh exports) so that `sparkrun run` applies them
# automatically. This standalone file exists for:
#   - docker / docker-compose runs that take an --env-file
#   - manual `export $(grep -v '^#' mimo-v2.5-dflash.env | xargs)` sessions
#   - the upstream scripts/serve.sh workflow
# Keep the two in sync if you change anything.

# --- vLLM / NVFP4 / FlashInfer FP4 MoE (GB10 / SM121) ---
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
VLLM_ALLOW_LONG_MAX_MODEL_LEN=1
VLLM_NVFP4_GEMM_BACKEND=flashinfer-cutlass
VLLM_USE_FLASHINFER_MOE_FP4=1
VLLM_FLASHINFER_MOE_BACKEND=throughput
VLLM_WORKER_MULTIPROC_METHOD=fork

# --- CUDA arch (GB10 = sm_121a / Blackwell) ---
# TORCH_* is from upstream serve.sh; FLASHINFER_* is added for parity with this
# repo's convention (matters at build time for the FP4 kernels).
TORCH_CUDA_ARCH_LIST=12.1a
FLASHINFER_CUDA_ARCH_LIST=12.1a

# --- NCCL over the ConnectX-7 link between the two Sparks (upstream tuning) ---
# NB: intentionally different from deepseek-v4-flash.env's IB settings — this is
# the MiMo author's tuning for the GB10 interconnect.
NCCL_CUMEM_ENABLE=0
NCCL_NVLS_ENABLE=0
NCCL_MAX_NCHANNELS=2
NCCL_NET_GDR_LEVEL=LOC
NCCL_PROTO=LL

# --- DFlash drafter location (consumed by serve.sh; mirrors defaults.drafter_dir
#     in the YAML, which is substituted into the recipe's --speculative-config).
# Pre-download the drafter on BOTH nodes first (~2.9 GB); it must be local to each
# TP rank. Upstream: scripts/download-drafter.sh ~/.cache/huggingface/dflash-mimo-v2.5
# then DRAFTER_DIR points at the dflash/ subdir. Keep this in sync with
# defaults.drafter_dir in mimo-v2.5-dflash.yaml.
DRAFTER_DIR=/root/.cache/huggingface/dflash-mimo-v2.5/dflash

# --- Chat template baked into the image (vendored from PR #46104) ---
MIMO_DFLASH_CHAT_TEMPLATE=/opt/mimo-dflash/mods/mimo-dflash-pr46104/chat_template.jinja

# --- Per-node multi-node coordination (set by the orchestrator, NOT here) -------
# sparkrun's vllm-distributed runtime injects NODE_RANK / MASTER_ADDR; only set
# them manually if you launch the container yourself (raw docker run per node):
#   NODE_RANK=0                   # 0 on the head/master node, 1 on the worker
#   MASTER_ADDR=169.254.225.22    # head node CX-7 IP
#   MASTER_PORT=25000
