# Environment for Qwen3.6-35B-A3B NVFP4-Fast (Unsloth) recipe — DGX Spark GB10
# Source: https://unsloth.ai/docs/models/qwen3.6 (DGX Spark section)
#
# These mirror the `env:` block of qwen3.6-35b-a3b-nvfp4-fast.yaml so that
# `sparkrun run` applies them automatically. This standalone file exists for:
#   - docker / docker-compose runs that take an --env-file
#   - manual `export $(grep -v '^#' qwen3.6-35b-a3b-nvfp4-fast.env | xargs)` sessions
# Keep the two in sync if you change anything.

# --- Unsloth Spark instruction: cute-DSL kernels target GB10 (sm_121a) ---
CUTE_DSL_ARCH=sm_121a

# --- Allow max_model_len beyond native 262144 (YaRN-extended 1M) ---
VLLM_ALLOW_LONG_MAX_MODEL_LEN=1

# --- CUDA arch (GB10 = sm_121a / Blackwell) ---
TORCH_CUDA_ARCH_LIST=12.1a
FLASHINFER_CUDA_ARCH_LIST=12.1a

# --- Worker spawn method (crash-avoidance at TP=2; harmless at TP=1) ---
VLLM_WORKER_MULTIPROC_METHOD=fork

# --- NCCL over the ConnectX-7 IB link — only exercised at --tp 2 ---
NCCL_NET=IB
NCCL_IB_DISABLE=0
NCCL_IB_GID_INDEX=3
NCCL_CROSS_NIC=1
NCCL_CUMEM_ENABLE=0
NCCL_IGNORE_CPU_AFFINITY=1
NCCL_DEBUG=WARN

# --- Per-node multi-node coordination (set by the orchestrator, NOT here) ---
# sparkrun injects NODE_RANK / MASTER_ADDR at --tp 2; only set them manually for
# raw docker runs:
#   NODE_RANK=0                   # 0 on the head/master node, 1 on the worker
#   MASTER_ADDR=169.254.225.22    # head node CX-7 IP
#   MASTER_PORT=25000
