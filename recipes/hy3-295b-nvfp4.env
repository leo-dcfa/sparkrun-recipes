# Environment for Hy3-295B (Hunyuan 3) NVFP4-W4A16 + MTP recipe (DGX Spark GB10, 2 nodes)
# Source: https://forums.developer.nvidia.com/t/hy3-295b-hunyuan-3-nvfp4-w4a16-mtp-speculative-on-2x-dgx-spark-gb10-128k-ctx-21-8-tok-s-single-59-7-tok-s-6-way/375851
#
# These mirror the `env:` block of hy3-295b-nvfp4.yaml so that `sparkrun run`
# applies them automatically. This standalone file exists for:
#   - docker / docker-compose runs that take an --env-file
#   - manual `export $(grep -v '^#' hy3-295b-nvfp4.env | xargs)` sessions
# Keep the two in sync if you change anything.
#
# NB: the quant author states no env vars are strictly required. The arch pins are
# repo convention (build-time) and the NCCL block is the homelab's standard IB tuning
# (the forum recipe specified ray + CX-7 MTU 9000 but no explicit NCCL knobs).

# --- Worker spawn method ---
# The headless peer worker crashes under vLLM's default `spawn` with a
# multiprocessing semaphore restore error (synchronize.py __setstate__ ->
# FileNotFoundError on /dev/shm/mp-*), hanging the head at NCCL rendezvous. `fork`
# inherits semaphores instead of re-opening them. Same as the mimo recipe. (2026-07-09)
VLLM_WORKER_MULTIPROC_METHOD=fork

# --- CUDA arch (GB10 = sm_121a / Blackwell) ---
TORCH_CUDA_ARCH_LIST=12.1a
FLASHINFER_CUDA_ARCH_LIST=12.1a

# --- NCCL over the ConnectX-7 / InfiniBand-RoCE link between the two Sparks ---
# NB: the forum recipe did NOT specify NCCL tuning; these are the homelab's
# standard IB settings. Adjust if cross-node all-reduce misbehaves.
NCCL_NET=IB
NCCL_IB_DISABLE=0
NCCL_IB_GID_INDEX=3
NCCL_CROSS_NIC=1
NCCL_CUMEM_ENABLE=0
NCCL_IGNORE_CPU_AFFINITY=1
NCCL_DEBUG=WARN

# --- Per-node multi-node coordination (set by the orchestrator, NOT here) -------
# sparkrun's vllm-distributed runtime injects NODE_RANK / MASTER_ADDR; only set
# them manually if you launch the container yourself (raw docker run per node):
#   NODE_RANK=0                   # 0 on the head/master node, 1 on the worker
#   MASTER_ADDR=169.254.225.22    # head node CX-7 IP
#   MASTER_PORT=25000
