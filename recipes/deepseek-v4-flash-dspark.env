# Environment for DeepSeek-V4-Flash (DSpark) recipe (DGX Spark GB10, 2 nodes)
# Source: https://forums.developer.nvidia.com/t/instructions-for-running-deepseek-v4-flash-with-dspark-using-eugrs-repo/376220
#
# These mirror the `env:` block of deepseek-v4-flash-dspark.yaml so that `sparkrun run`
# applies them automatically. This standalone file exists for:
#   - docker / docker-compose runs that take an --env-file
#   - manual `export $(grep -v '^#' deepseek-v4-flash-dspark.env | xargs)` sessions
# Keep the two in sync if you change anything.
#
# The DG_/VLLM_ vars below are the forum recipe's. The arch pins, the `fork` spawn
# method, and the NCCL block are homelab additions (the forum used a hand-rolled ray
# cluster with CX-7 MTU 9000 but no explicit NCCL knobs) — same convention hy3/mimo use.

# --- Forum recipe env ---
DG_JIT_USE_NVRTC=0
VLLM_ALLOW_LONG_MAX_MODEL_LEN=1
VLLM_USE_BREAKABLE_CUDAGRAPH=0
# Gated model — set your real token here for --env-file use, or export HF_TOKEN
# before launch. The YAML recipe interpolates ${HF_TOKEN} from the launching shell.
HF_TOKEN=

# --- Worker spawn method (homelab addition) ---
# The headless peer worker crashes under vLLM's default `spawn` with a multiprocessing
# semaphore restore error (synchronize.py __setstate__ -> FileNotFoundError on
# /dev/shm/mp-*), hanging the head at NCCL rendezvous. `fork` inherits semaphores
# instead of re-opening them. Same as hy3/mimo.
VLLM_WORKER_MULTIPROC_METHOD=fork

# --- CUDA arch (GB10 = sm_121a / Blackwell) ---
TORCH_CUDA_ARCH_LIST=12.1a
FLASHINFER_CUDA_ARCH_LIST=12.1a

# --- NCCL over the ConnectX-7 / InfiniBand-RoCE link between the two Sparks ---
# Homelab standard IB tuning (the forum specified only ray + CX-7 MTU 9000). Adjust
# if cross-node all-reduce misbehaves.
NCCL_NET=IB
NCCL_IB_DISABLE=0
NCCL_IB_GID_INDEX=3
NCCL_CROSS_NIC=1
NCCL_CUMEM_ENABLE=0
NCCL_IGNORE_CPU_AFFINITY=1
NCCL_DEBUG=WARN

# --- Per-node multi-node coordination (set by the orchestrator, NOT here) -------
# sparkrun's vllm-distributed runtime injects NODE_RANK / MASTER_ADDR; only set them
# manually if you launch the container yourself (raw docker run per node):
#   NODE_RANK=0                   # 0 on the head/master node, 1 on the worker
#   MASTER_ADDR=169.254.225.22    # head node CX-7 IP
#   MASTER_PORT=25000
