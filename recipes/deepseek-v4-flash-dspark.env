# Environment for DeepSeek-V4-Flash (DSpark) recipe (DGX Spark GB10, 2 nodes)
# Source: https://github.com/tonyd2wild/DeepSeek-v4-Flash-DSpark-1M-NVFP4-KV-2x-DGX-Spark
#
# These mirror the `env:` block of deepseek-v4-flash-dspark.yaml so that `sparkrun run`
# applies them automatically. This standalone file exists for:
#   - docker / docker-compose runs that take an --env-file
#   - manual `export $(grep -v '^#' deepseek-v4-flash-dspark.env | xargs)` sessions
# Keep the two in sync if you change anything.
#
# Values mirror upstream's docker-compose.dspark.yml / .env.dspark.example defaults.
# The `fork` spawn method and NCCL_IB_GID_INDEX=3 are homelab additions/overrides.

# --- DSpark garble fix (2026-07-03) — FlashInfer sampler is part of it ---
VLLM_USE_FLASHINFER_SAMPLER=1

# --- Long-context crash fix: clamp stale DSpark draft-KV slot ids (1 = clamp) ---
DSPARK_SLOT_CLAMP=1

# --- B12X MoE ---
# CRITICAL for speed. =1 gives the b12x Mxfp4 MoE backend (boot log "Using 'B12X'
# Mxfp4 MoE backend") for ~50-60 tok/s; =0 silently falls back to DEEPGEMM_MXFP4 and
# tanks decode to ~29 tok/s. Keep 1.
# Do NOT add VLLM_USE_B12X_FP8_GEMM=1 — DeepGEMM layout assert during drafter warmup.
VLLM_USE_B12X_MOE=1
VLLM_USE_B12X_WO_PROJECTION=1
VLLM_B12X_W4A16_FORCE_BLOCKS_PER_SM=0
VLLM_B12X_W4A16_FORCE_BLOCKS_MAX_M=16
VLLM_B12X_W4A16_FORCE_TILE_CONFIG=
B12X_W4A16_TC_DECODE=0

# --- DSpark drafter switches from the validated 1M run ---
VLLM_DSPARK_CONFIDENCE_THRESHOLD=0.0
VLLM_DSPARK_CONFIDENCE_SCHEDULER=off
VLLM_DSPARK_LOCAL_ARGMAX=1
VLLM_DSPARK_REPLICATE_MARKOV_W1=1
VLLM_DSPARK_FUSED_MARKOV_ARGMAX=0
VLLM_DSPARK_GPU_REJECTED_CONTEXT_MASK=1
VLLM_DSPARK_REFERENCE_KV_QUANT_DEQUANT=0
VLLM_DSPARK_HARDWARE_SCHEDULER_EARLY_STOP=1
VLLM_DSV4_B12X_COMPRESSED_MLA=0
VLLM_DSV4_DSPARK_DEFER_TARGET_CAPTURE=0
VLLM_DSV4_DSPARK_DEFER_TARGET_CAPTURE_EXACT=0

# --- vLLM runtime defaults ---
# Do NOT set VLLM_USE_V2_MODEL_RUNNER=1: hard-rejected with DSpark spec decode.
VLLM_ALLOW_LONG_MAX_MODEL_LEN=1
VLLM_TRITON_MLA_SPARSE=1
VLLM_SPARSE_INDEXER_MAX_LOGITS_MB=256
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=0
VLLM_SKIP_INIT_MEMORY_CHECK=1
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# --- JIT / toolchain (paths are Stage-C-image specific) ---
DG_JIT_USE_NVRTC=0
DG_JIT_NVCC_COMPILER=/opt/env/bin/nvcc
TILELANG_CLEANUP_TEMP_FILES=1
FLASHINFER_DISABLE_VERSION_CHECK=1

# --- HF ---
HF_HUB_DISABLE_XET=1
# Public (non-gated) checkpoint — a token is NOT required, but passing one avoids
# anonymous rate limits. Set it here for --env-file use, or export HF_TOKEN before
# launch (the YAML recipe interpolates ${HF_TOKEN} from the launching shell).
HF_TOKEN=

# --- Worker spawn method (homelab addition) ---
# The headless peer worker crashes under vLLM's default `spawn` with a multiprocessing
# semaphore restore error (synchronize.py __setstate__ -> FileNotFoundError on
# /dev/shm/mp-*), hanging the head at NCCL rendezvous. `fork` inherits semaphores
# instead of re-opening them. Same as hy3/mimo.
VLLM_WORKER_MULTIPROC_METHOD=fork

# --- CUDA arch (GB10 = sm_121a / Blackwell) ---
TORCH_CUDA_ARCH_LIST=12.1a
FLASHINFER_CUDA_ARCH_LIST=12.1a

# --- NCCL over the ConnectX-7 / InfiniBand-RoCE link between the two Sparks ---
# Upstream runs RoCE on 192.168.192.0/24 with per-node NCCL_IB_HCA / NCCL_SOCKET_IFNAME;
# those are left to sparkrun. GID_INDEX 3 is the homelab value (upstream's example
# says 0). Adjust if cross-node all-reduce misbehaves.
NCCL_NET=IB
NCCL_IB_DISABLE=0
NCCL_IB_GID_INDEX=3
NCCL_CROSS_NIC=1
NCCL_CUMEM_ENABLE=0
NCCL_IGNORE_CPU_AFFINITY=1
NCCL_NVLS_ENABLE=0
NCCL_DEBUG=WARN

# --- Per-node multi-node coordination (set by the orchestrator, NOT here) -------
# sparkrun's vllm-distributed runtime injects NODE_RANK / MASTER_ADDR; only set them
# manually if you launch the container yourself (raw docker run per node). Upstream's
# compose also sets VLLM_HOST_IP per node to that node's RoCE IP:
#   NODE_RANK=0                   # 0 on the head/master node, 1 on the worker
#   HEADLESS=1                    # worker only
#   MASTER_ADDR=169.254.225.22    # head node CX-7 IP
#   MASTER_PORT=25000
#   VLLM_HOST_IP=<this node's CX-7 IP>
