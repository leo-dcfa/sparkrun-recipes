# Environment for Ornith-1.0-397B INT4 (W4A16 AutoRound) recipe (DGX Spark GB10, 2 nodes)
# Source: https://forums.developer.nvidia.com/t/ornith-1-0-397b-released-has-anyone-tested-it-yet-or-found-the-best-inference-settings/374601
#
# These mirror the `env:` block of ornith-1.0-397b.yaml so that `sparkrun run`
# applies them automatically. This standalone file exists for:
#   - docker / docker-compose runs that take an --env-file
#   - manual `export $(grep -v '^#' ornith-1.0-397b.env | xargs)` sessions
# Keep the two in sync if you change anything.

# --- vLLM INT4 (Marlin) + memory profiler tweaks (from the forum recipe) ---
VLLM_MARLIN_USE_ATOMIC_ADD=1
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=0

# --- CUDA arch (GB10 = sm_121a / Blackwell) ---
TORCH_CUDA_ARCH_LIST=12.1a
FLASHINFER_CUDA_ARCH_LIST=12.1a

# --- NCCL over the ConnectX-7 / InfiniBand-RoCE link between the two Sparks ---
# NB: the forum recipe did NOT specify NCCL tuning; these are the homelab's
# standard IB settings. Adjust if cross-node all-reduce misbehaves.
NCCL_NET=IB
NCCL_IB_DISABLE=0
NCCL_IB_GID_INDEX=3
NCCL_CROSS_NIC=1
NCCL_CUMEM_ENABLE=0
NCCL_IGNORE_CPU_AFFINITY=1
NCCL_DEBUG=WARN

# --- Per-node multi-node coordination (set by the orchestrator, NOT here) -------
# sparkrun's vllm-distributed runtime injects NODE_RANK / MASTER_ADDR; only set
# them manually if you launch the container yourself (raw docker run per node):
#   NODE_RANK=0                   # 0 on the head/master node, 1 on the worker
#   MASTER_ADDR=169.254.225.22    # head node CX-7 IP
#   MASTER_PORT=25000
